@model LeaveManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

<div class="container-fluid py-4 leave-admin-create-page">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">

            <div class="card shadow-sm border-0">
                <!-- Header -->
                <div class="card-header bg-white border-0 pb-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="h4 mb-1">Add Employee</h2>
                            <p class="text-muted small mb-0">
                                Fill in the employee details to add a new staff to the system.
                            </p>
                        </div>

                        <a asp-action="Index" class="btn btn-link text-primary fw-semibold">
                            <i class="bi bi-arrow-left me-1"></i> Back to list
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <h6 class="text-uppercase text-muted small mb-3">Employee Information</h6>

                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label small fw-semibold">Full Name</label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                                    <input asp-for="Email" class="form-control" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h6 class="text-uppercase text-muted small mb-3">Employment Details</h6>

                                <div class="mb-3">
                                    <label asp-for="Department" class="form-label small fw-semibold">Department</label>
                                    <select asp-for="Department" class="form-select">
                                        <option value="">-- Select Department --</option>
                                        <option>IT</option>
                                        <option>HR</option>
                                        <option>Sales</option>
                                        <option>Finance</option>
                                        <option>Operations</option>
                                        <option>Support</option>
                                    </select>
                                    <span asp-validation-for="Department" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EmploymentType" class="form-label small fw-semibold">Employment Type</label>
                                    <select asp-for="EmploymentType" class="form-select">
                                        <option value="">-- Select Employment Type --</option>
                                        <option>Permanent</option>
                                        <option>Contract</option>
                                        <option>Part-Time</option>
                                        <option>Intern</option>
                                        <option>Probation</option>
                                    </select>
                                    <span asp-validation-for="EmploymentType" class="text-danger small"></span>
                                </div>

                                <div class="mb-1">
                                    <label asp-for="JoinDate" class="form-label small fw-semibold">Join Date</label>
                                    <input asp-for="JoinDate" class="form-control" type="date" />
                                    <span asp-validation-for="JoinDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-plus-fill me-1"></i> Add Employee
                            </button>

                            <span class="text-muted small"></span>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                themeSystem: 'bootstrap5',

                headerToolbar: false,

                events: function (info, successCallback, failureCallback) {
                    $.ajax({
                        url: '@Url.Action("GetLeaveEvents", "Home")',
                        data: {
                            start: info.startStr,
                            end: info.endStr
                        },
                        success: function (data) {
                            successCallback(data);
                        },
                        error: function () {
                            failureCallback();
                        }
                    });
                },

                eventClick: function (info) {
                    if (info.event.url) {
                        info.jsEvent.preventDefault();

                        window.location.href = info.event.url;
                    }
                },

            });

            calendar.render();

            var btnPrev = document.getElementById('btnPrev');
            var btnNext = document.getElementById('btnNext');
            var btnToday = document.getElementById('btnToday');
            var btnMonth = document.getElementById('btnMonth');
            var btnList = document.getElementById('btnList');

            if (btnPrev) {
                btnPrev.addEventListener('click', function () {
                    calendar.prev();
                });
            }

            if (btnNext) {
                btnNext.addEventListener('click', function () {
                    calendar.next();
                });
            }

            if (btnToday) {
                btnToday.addEventListener('click', function () {
                    calendar.today();
                });
            }

            if (btnMonth) {
                btnMonth.addEventListener('click', function () {
                    calendar.changeView('dayGridMonth');
                });
            }

            if (btnList) {
                btnList.addEventListener('click', function () {
                    calendar.changeView('listMonth');
                });
            }
        });
    </script>

    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}