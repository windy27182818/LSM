@model LeaveManagementSystem.ViewModels.LeaveAdminViewModel

@{
    ViewData["Title"] = "Edit Annual Leave";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-1">Edit Annual Leave</h3>
            <p class="text-muted mb-0">
                Update annual leave entitlement / usage for this employee.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <form asp-action="EditAnnual" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Employee Info -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted mb-3">Employee Info</h6>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input asp-for="Name" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <input asp-for="Department" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Employment Type</label>
                            <input asp-for="EmploymentType" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Join Date</label>
                            <input asp-for="JoinDate" type="date" class="form-control" readonly />
                        </div>
                    </div>
                </div>

                <!-- Annual Leave -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted mb-3">Annual Leave</h6>

                    <div class="row g-3 leave-block">
                        <div class="col-md-4">
                            <label class="form-label">Entitlement (days)</label>
                            <input asp-for="AnnualLeaveEntitlement" class="form-control calc-ent" type="number" step="0.5" min="0" />
                            <span asp-validation-for="AnnualLeaveEntitlement" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Used (current year)</label>
                            <input asp-for="AnnualLeaveUsed" class="form-control calc-used" type="number" step="0.5" min="0" />
                            <span asp-validation-for="AnnualLeaveUsed" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Balance</label>
                            <input asp-for="AnnualLeaveBalance" class="form-control calc-bal" type="number" step="0.5" readonly />
                            <small class="text-muted">Automatically calculated as Entitlement − Used.</small>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function recalc() {
                const block = document.querySelector(".leave-block");
                if (!block) return;

                const ent = block.querySelector(".calc-ent");
                const used = block.querySelector(".calc-used");
                const bal = block.querySelector(".calc-bal");

                if (!ent || !used || !bal) return;

                const entVal = parseFloat(ent.value || "0");
                const usedVal = parseFloat(used.value || "0");

                let result = entVal - usedVal;
                if (result < 0) result = 0;

                bal.value = result;
            }

            recalc();
            document.addEventListener("input", function (e) {
                if (e.target.classList.contains("calc-ent") || e.target.classList.contains("calc-used")) {
                    recalc();
                }
            });
        })();
    </script>
}
