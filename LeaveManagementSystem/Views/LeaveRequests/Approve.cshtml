@model LeaveManagementSystem.Models.LeaveRequest

<h2>Approve Leave Request</h2>

<div>
    <strong>Employee:</strong> @Model.Employee!.Name <br />
    <strong>Leave Type:</strong> @Model.LeaveType!.Name <br />
    <strong>Period:</strong> @Model.StartDate.ToShortDateString() - @Model.EndDate.ToShortDateString() <br />
    <strong>Total Days:</strong> @Model.TotalDays <br />
    <strong>Reason:</strong> @Model.Reason <br />
</div>

<form asp-action="ApproveConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="form-group mt-3">
        <label>Remark</label>
        <textarea name="remark" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success mt-3">Approve</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>
